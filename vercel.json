{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "outputDirectory": "packages/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/r/:id", "destination": "/api/share-page" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
