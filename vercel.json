{
  "buildCommand": "bun scripts/build-api.ts && cd packages/web && npx vite build",
  "installCommand": "bun install",
  "outputDirectory": "packages/web/dist",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "node_modules/@libsql/**,node_modules/@vercel/og/**,node_modules/react/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/r/:id", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
