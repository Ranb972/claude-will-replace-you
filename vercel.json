{
  "buildCommand": "cd packages/web && npx vite build",
  "installCommand": "bun install",
  "outputDirectory": "packages/web/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "packages/api/**,drizzle/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/r/:id", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
